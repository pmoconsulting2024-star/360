<?xml version="1.0" encoding="UTF-8"?>
<OfficeApp
  xmlns="http://schemas.microsoft.com/office/appforoffice/1.1"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0"
  xmlns:ov="http://schemas.microsoft.com/office/taskpaneappversionoverrides"
  xsi:type="TaskPaneApp">

  <!-- ═══════════════════════════════════════════════
       VISOR 360° — Office Add-in para PowerPoint
       Compatible con: Kuula, Matterport, Pannellum,
                       RoundMe, YouTube 360 y más.
       ═══════════════════════════════════════════════ -->

  <Id>277976BB-5DFB-41E5-A316-3CFFBF8B38B3</Id>
  <Version>1.0.0.0</Version>
  <ProviderName>PMO Consulting</ProviderName>
  <DefaultLocale>es-MX</DefaultLocale>

  <DisplayName DefaultValue="Visor 360°"/>
  <Description DefaultValue="Visualiza imágenes y tours 360° desde Kuula, Matterport, Pannellum y otras plataformas directamente en PowerPoint."/>
  <IconUrl DefaultValue="https://raw.githubusercontent.com/microsoft/office-js/master/docs/images/logo-filled.png"/>
  <HighResolutionIconUrl DefaultValue="https://raw.githubusercontent.com/microsoft/office-js/master/docs/images/logo-filled.png"/>
  <SupportUrl DefaultValue="https://support.microsoft.com"/>

  <AppDomains>
    <!-- Dominios permitidos para cargar dentro del panel -->
    <AppDomain>https://kuula.co</AppDomain>
    <AppDomain>https://my.matterport.com</AppDomain>
    <AppDomain>https://pannellum.org</AppDomain>
    <AppDomain>https://roundme.com</AppDomain>
    <AppDomain>https://www.youtube.com</AppDomain>
    <AppDomain>https://storage.googleapis.com</AppDomain>
  </AppDomains>

  <Hosts>
    <Host Name="Presentation"/>
  </Hosts>

  <DefaultSettings>
    <!-- Apunta al archivo taskpane.html en la MISMA carpeta que este manifest -->
    <SourceLocation DefaultValue="taskpane.html"/>
  </DefaultSettings>

  <Permissions>ReadWriteDocument</Permissions>

  <!-- ── Ribbon button con VersionOverrides ── -->
  <VersionOverrides xmlns="http://schemas.microsoft.com/office/taskpaneappversionoverrides" xsi:type="VersionOverridesV1_0">

    <Hosts>
      <Host xsi:type="Presentation">
        <AllFormFactors/>
        <DesktopFormFactor>

          <GetStarted>
            <Title resid="GetStarted.Title"/>
            <Description resid="GetStarted.Description"/>
            <LearnMoreUrl resid="GetStarted.LearnMoreUrl"/>
          </GetStarted>

          <!-- Función helper (requerida aunque esté vacía) -->
          <FunctionFile resid="Commands.Url"/>

          <!-- Botón en la cinta de opciones -->
          <ExtensionPoint xsi:type="PrimaryCommandSurface">
            <OfficeTab id="TabHome">
              <Group id="Visor360.Group">
                <Label resid="CommandsGroup.Label"/>
                <Icon>
                  <bt:Image size="16" resid="Icon.16x16"/>
                  <bt:Image size="32" resid="Icon.32x32"/>
                  <bt:Image size="80" resid="Icon.80x80"/>
                </Icon>

                <Control xsi:type="Button" id="Visor360.ShowPaneButton">
                  <Label resid="TaskpaneButton.Label"/>
                  <Supertip>
                    <Title resid="TaskpaneButton.Label"/>
                    <Description resid="TaskpaneButton.Tooltip"/>
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="Icon.16x16"/>
                    <bt:Image size="32" resid="Icon.32x32"/>
                    <bt:Image size="80" resid="Icon.80x80"/>
                  </Icon>
                  <Action xsi:type="ShowTaskPane">
                    <TaskpaneId>ButtonId1</TaskpaneId>
                    <SourceLocation resid="Taskpane.Url"/>
                  </Action>
                </Control>

              </Group>
            </OfficeTab>
          </ExtensionPoint>

        </DesktopFormFactor>
      </Host>
    </Hosts>

    <Resources>
      <bt:Images>
        <!-- Icono SVG de globo terráqueo (base64 PNG 32x32, azul) -->
        <bt:Image id="Icon.16x16"
          DefaultValue="https://upload.wikimedia.org/wikipedia/commons/thumb/8/8d/Globe_icon_%28blue%29.svg/16px-Globe_icon_%28blue%29.svg.png"/>
        <bt:Image id="Icon.32x32"
          DefaultValue="https://upload.wikimedia.org/wikipedia/commons/thumb/8/8d/Globe_icon_%28blue%29.svg/32px-Globe_icon_%28blue%29.svg.png"/>
        <bt:Image id="Icon.80x80"
          DefaultValue="https://upload.wikimedia.org/wikipedia/commons/thumb/8/8d/Globe_icon_%28blue%29.svg/80px-Globe_icon_%28blue%29.svg.png"/>
      </bt:Images>

      <bt:Urls>
        <bt:Url id="GetStarted.LearnMoreUrl"  DefaultValue="https://kuula.co/help/embed-integration"/>
        <bt:Url id="Commands.Url"             DefaultValue="taskpane.html"/>
        <bt:Url id="Taskpane.Url"             DefaultValue="taskpane.html"/>
      </bt:Urls>

      <bt:ShortStrings>
        <bt:String id="GetStarted.Title"       DefaultValue="Visor 360° listo"/>
        <bt:String id="CommandsGroup.Label"    DefaultValue="360°"/>
        <bt:String id="TaskpaneButton.Label"   DefaultValue="Visor 360°"/>
      </bt:ShortStrings>

      <bt:LongStrings>
        <bt:String id="GetStarted.Description"
          DefaultValue="Pega cualquier URL de Kuula, Matterport u otra plataforma 360° para visualizarla aquí."/>
        <bt:String id="TaskpaneButton.Tooltip"
          DefaultValue="Abre el panel para visualizar imágenes y tours 360° desde cualquier URL compatible."/>
      </bt:LongStrings>
    </Resources>

  </VersionOverrides>
</OfficeApp>
